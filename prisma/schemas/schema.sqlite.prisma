generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 認証・テナント ====================

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]
  todos     Todo[]
  tags      Tag[]
  auditLogs AuditLog[]

  @@map("Tenants")
}

model Admin {
  id             Int                  @id @default(autoincrement())
  email          String               @unique
  passwordHash   String               @map("password_hash")
  name           String
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  refreshTokens  AdminRefreshToken[]
  passwordResets AdminPasswordReset[]

  @@map("Admins")
}

model AdminRefreshToken {
  id        Int      @id @default(autoincrement())
  adminId   Int      @map("admin_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("AdminRefreshTokens")
}

model AdminPasswordReset {
  id        Int       @id @default(autoincrement())
  adminId   Int       @map("admin_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("AdminPasswordResets")
}

model User {
  id             Int                  @id @default(autoincrement())
  tenantId       Int                  @map("tenant_id")
  role           String               // 'tenant_admin' | 'tenant_user'
  email          String               @unique
  passwordHash   String               @map("password_hash")
  name           String
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  refreshTokens  UserRefreshToken[]
  passwordResets UserPasswordReset[]

  @@map("Users")
}

model UserRefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("RefreshTokens")
}

model UserPasswordReset {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("PasswordResets")
}

// ==================== ドメイン ====================

model Todo {
  id        Int       @id @default(autoincrement())
  tenantId  Int       @map("tenant_id")
  title     String
  completed Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  todoTags  TodoTag[]

  @@map("Todos")
}

model Tag {
  id        Int       @id @default(autoincrement())
  tenantId  Int       @map("tenant_id")
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  todoTags  TodoTag[]

  @@unique([tenantId, name])
  @@map("Tags")
}

model TodoTag {
  todoId Int  @map("todo_id")
  tagId  Int  @map("tag_id")
  todo   Todo @relation(fields: [todoId], references: [id], onDelete: NoAction)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: NoAction)

  @@id([todoId, tagId])
  @@map("TodoTags")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  tenantId     Int      @map("tenant_id")
  actorType    String   @map("actor_type") // 'admin' | 'user'
  actorId      Int      @map("actor_id")
  action       String   // 'create' | 'update' | 'delete'
  resourceType String   @map("resource_type") // 'Todo', 'Tag', etc.
  resourceId   Int      @map("resource_id")
  before       String?
  after        String?
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@map("AuditLogs")
}
