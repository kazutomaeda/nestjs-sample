# --- DB 接続文字列（使用する DB に合わせて1つだけ有効にする） ---
# MySQL (default)
DATABASE_URL="mysql://root:password@localhost:3307/nestjs_sample"
# SQL Server
# DATABASE_URL="sqlserver://localhost:1434;database=nestjs_sample;user=sa;password=YourStrong!Passw0rd;trustServerCertificate=true"
# PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/nestjs_sample"
# SQLite
# DATABASE_URL="file:./dev.db"
PORT=3002

# 認証
JWT_SECRET="your-secret-key-change-in-production"
# JWT_ACCESS_TOKEN_EXPIRES_IN=900       # アクセストークン有効期限（秒）。デフォルト: 900（15分）
# JWT_REFRESH_TOKEN_EXPIRES_IN_DAYS=7   # リフレッシュトークン有効期限（日）。デフォルト: 7
# NODE_ENV=development

# CORS
# CORS_ORIGIN=http://localhost:3000       # 許可オリジン。カンマ区切りで複数指定可。未設定時: リクエストオリジンを動的反映

# MinIO (S3互換ストレージ)
MINIO_ENDPOINT="http://localhost:9002"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="nestjs-sample"
# MINIO_API_PORT=9002              # ホスト側ポート（docker-compose用）。デフォルト: 9002
# MINIO_CONSOLE_PORT=9003          # MinIO Console ポート。デフォルト: 9003

# メール (SMTP)
SMTP_HOST="localhost"
SMTP_PORT=1025
