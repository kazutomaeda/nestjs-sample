# --- DB 接続文字列（使用する DB に合わせて1つだけ有効にする） ---
# SQL Server (default)
DATABASE_URL="sqlserver://localhost:1434;database=nestjs_sample;user=sa;password=YourStrong!Passw0rd;trustServerCertificate=true"
# PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/nestjs_sample"
# MySQL
# DATABASE_URL="mysql://root:password@localhost:3306/nestjs_sample"
# SQLite
# DATABASE_URL="file:./dev.db"
PORT=3000

# 認証
JWT_SECRET="your-secret-key-change-in-production"
# JWT_ACCESS_TOKEN_EXPIRES_IN=900       # アクセストークン有効期限（秒）。デフォルト: 900（15分）
# JWT_REFRESH_TOKEN_EXPIRES_IN_DAYS=7   # リフレッシュトークン有効期限（日）。デフォルト: 7
# NODE_ENV=development

# CORS
# CORS_ORIGIN=http://localhost:3000       # 許可オリジン。カンマ区切りで複数指定可。未設定時: リクエストオリジンを動的反映
